    given-names: Quyen
    orcid: "https://orcid.org/0000-0002-9863-0486"
  - family-names: "O'Brien"
    given-names: "Edward P."
version: "2026.1"
date-released: "2026-07-12"
license: GPL-3.0-or-later
url: "https://github.com/vuqv/cosmo"
repository-code: "https://github.com/vuqv/cosmo"
keywords:
  - coarse-grained
  - molecular-dynamics
  - intrinsically-disordered-proteins
  - biomolecular-condensates
  - phase-separation
  - HPS-model
  - Mpipi
  - co-translational-synthesis
  - OpenMM
# The application paper that introduces this coarse-grained toolkit. GitHub
